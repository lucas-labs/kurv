{
    "singleQuote": true,
    "tabWidth": 4,
    "printWidth": 100,
    "plugins": ["@trivago/prettier-plugin-sort-imports", "prettier-plugin-tailwindcss"],
    "importOrder": [
        "^react$",
        "^react/(.*)$",
        "^@tauri-apps/(.*)$",
        "^@radix-ui/(.*)$",
        "^@/(.*)$",
        "^[./](?!.*\\.css$)",
        "(.*)\\.css$"
    ],
    "importOrderSeparation": false,
    "importOrderSortSpecifiers": true
}
